---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'Javier Pino', description = 'Siervo de Jesucristo' } = Astro.props;
const path = Astro.url.pathname;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title === 'Javier Pino' ? title : `${title} — Javier Pino`}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="brand">
        <span class="brand-name">Javier Pino</span>
        <span class="brand-sub">Siervo de Jesucristo</span>
      </a>
      <nav class="nav">
        <a href="/articulos" class:list={['nav-link', { active: path.startsWith('/articulos') }]}>Artículos</a>
        <a href="/podcast" class:list={['nav-link', { active: path.startsWith('/podcast') }]}>Podcast</a>
        <a href="/recursos" class:list={['nav-link', { active: path.startsWith('/recursos') }]}>Recursos</a>
      </nav>
      <button class="menu-btn" id="menu-btn" aria-label="Menú">
        <span></span><span></span><span></span>
      </button>
    </div>
    <nav class="mobile-nav" id="mobile-nav">
      <a href="/articulos" class="mobile-link">Artículos</a>
      <a href="/podcast" class="mobile-link">Podcast</a>
      <a href="/recursos" class="mobile-link">Recursos</a>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p class="footer-brand">Javier Pino</p>
      <p class="footer-sub">Siervo de Jesucristo · Neuquén, Argentina</p>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('menu-btn');
    const nav = document.getElementById('mobile-nav');
    btn?.addEventListener('click', () => nav?.classList.toggle('open'));
  </script>

</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy:   #0D1B3E;
    --navy2:  #162348;
    --gold:   #B8960C;
    --gold-l: #D4AF37;
    --white:  #FFFFFF;
    --off:    #F8F7F4;
    --line:   #E8E4DC;
    --ink:    #1A1A1A;
    --ink2:   #6B6B6B;
    --fd: 'Playfair Display', Georgia, serif;
    --fs: 'DM Sans', system-ui, sans-serif;
  }

  html { scroll-behavior: smooth; }
  body { font-family: var(--fs); color: var(--ink); background: var(--white); line-height: 1.6; }
  a { text-decoration: none; color: inherit; }
  img { max-width: 100%; display: block; }

  /* HEADER */
  .site-header {
    position: sticky; top: 0; z-index: 100;
    background: var(--navy);
    border-bottom: 2px solid var(--gold);
  }
  .header-inner {
    max-width: 1200px; margin: 0 auto;
    padding: 0 2rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .brand { display: flex; flex-direction: column; gap: 1px; }
  .brand-name {
    font-family: var(--fd); font-size: 1.15rem; font-weight: 900;
    color: var(--white); letter-spacing: -0.01em; line-height: 1;
  }
  .brand-sub {
    font-size: .6rem; font-weight: 500; letter-spacing: .12em;
    text-transform: uppercase; color: var(--gold-l);
  }
  .nav { display: flex; gap: 2rem; }
  .nav-link {
    font-size: .72rem; font-weight: 600; letter-spacing: .1em;
    text-transform: uppercase; color: rgba(255,255,255,.65);
    transition: color .2s; padding: .25rem 0;
    border-bottom: 2px solid transparent;
  }
  .nav-link:hover, .nav-link.active {
    color: var(--white);
    border-bottom-color: var(--gold);
  }

  /* HAMBURGER */
  .menu-btn {
    display: none; flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer; padding: .5rem;
  }
  .menu-btn span {
    display: block; width: 22px; height: 2px; background: white; transition: .3s;
  }
  .mobile-nav {
    display: none; flex-direction: column;
    background: var(--navy2); border-top: 1px solid rgba(255,255,255,.1);
  }
  .mobile-nav.open { display: flex; }
  .mobile-link {
    padding: 1rem 2rem;
    font-size: .8rem; font-weight: 600; letter-spacing: .1em;
    text-transform: uppercase; color: rgba(255,255,255,.75);
    border-bottom: 1px solid rgba(255,255,255,.07);
  }

  /* FOOTER */
  .site-footer {
    background: var(--navy); border-top: 2px solid var(--gold);
    margin-top: 4rem; padding: 2.5rem 2rem; text-align: center;
  }
  .footer-brand {
    font-family: var(--fd); font-size: 1.1rem; font-weight: 900;
    color: white; margin-bottom: .35rem;
  }
  .footer-sub { font-size: .68rem; color: rgba(255,255,255,.4); letter-spacing: .08em; text-transform: uppercase; }

  @media (max-width: 680px) {
    .nav { display: none; }
    .menu-btn { display: flex; }
  }
</style>
