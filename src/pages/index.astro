---
// javierpino.org — Sitio Premium
const siteTitle = "Javier Pino — Pastor & Teólogo";
const siteDesc = "Pastor bautista reformado, teólogo y estudiante de licenciatura en teología. Reflexiones, sermones y artículos desde la fe reformada.";
---

<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={siteDesc} />
<title>{siteTitle}</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --gold:#C9A84C;--gold-light:#F0D080;--gold-dark:#8B6914;
  --ink:#0A0A0F;--ink2:#1A1A2E;--ink3:#16213E;
  --cream:#FAF7F0;
  --accent:#4A6CF7;--accent2:#7B2FBE;
  --success:#1DB954;
  --glass:rgba(255,255,255,0.06);
  --border:rgba(201,168,76,0.22);--border2:rgba(201,168,76,0.48);
  --font-display:'Playfair Display',serif;
  --font-body:'DM Sans',sans-serif;
  --font-mono:'JetBrains Mono',monospace;
  --r:12px;--r2:20px;
  --shadow:0 8px 32px rgba(0,0,0,0.4);
}
html{scroll-behavior:smooth}
body{font-family:var(--font-body);background:var(--ink);color:var(--cream);min-height:100vh;overflow-x:hidden}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:var(--ink2)}
::-webkit-scrollbar-thumb{background:var(--gold);border-radius:3px}

/* ── NAVBAR ── */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;height:68px;
  padding:0 2.5rem;display:flex;align-items:center;justify-content:space-between;
  background:rgba(10,10,15,0.88);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);transition:box-shadow .3s;
}
.nav-logo{
  font-family:var(--font-display);font-size:1.45rem;font-weight:900;
  background:linear-gradient(135deg,var(--gold),var(--gold-light));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  text-decoration:none;
}
.nav-links{display:flex;gap:1.75rem;list-style:none;align-items:center}
.nav-links a{color:var(--cream);text-decoration:none;font-size:.825rem;font-weight:500;opacity:.65;transition:opacity .2s,color .2s;letter-spacing:.04em;text-transform:uppercase}
.nav-links a:hover{opacity:1;color:var(--gold)}
.nav-cta{background:linear-gradient(135deg,var(--gold),var(--gold-dark));color:var(--ink)!important;opacity:1!important;padding:.45rem 1.2rem;border-radius:50px;font-weight:700!important;transition:transform .2s,box-shadow .2s!important}
.nav-cta:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(201,168,76,0.4)!important}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:8px;background:none;border:none}
.hamburger span{width:22px;height:2px;background:var(--gold);border-radius:2px;display:block;transition:all .3s}

/* ── CUSTOMIZER ── */
.customizer{
  position:fixed;right:0;top:50%;transform:translateY(-50%);z-index:999;
  display:flex;flex-direction:column;gap:.5rem;padding:.6rem .45rem;
  background:rgba(10,10,15,0.9);backdrop-filter:blur(20px);
  border-left:1px solid var(--border);border-radius:var(--r2) 0 0 var(--r2);
}
.cust-btn{
  width:34px;height:34px;border-radius:8px;border:1px solid var(--border);
  background:var(--glass);display:flex;align-items:center;justify-content:center;
  font-size:.85rem;cursor:pointer;transition:all .2s;color:var(--cream);position:relative;
}
.cust-btn:hover{background:var(--gold);color:var(--ink);border-color:var(--gold)}
.cust-tooltip{
  position:absolute;right:calc(100% + 8px);background:var(--ink2);
  border:1px solid var(--border2);padding:.3rem .65rem;border-radius:6px;
  font-size:.68rem;white-space:nowrap;opacity:0;pointer-events:none;transition:opacity .2s;
}
.cust-btn:hover .cust-tooltip{opacity:1}

/* ── HERO ── */
.hero{
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  position:relative;overflow:hidden;padding:7rem 2rem 4rem;
}
.hero-bg{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 80% 55% at 50% 0%,rgba(74,108,247,.14) 0%,transparent 60%),
    radial-gradient(ellipse 50% 40% at 80% 80%,rgba(201,168,76,.1) 0%,transparent 60%),
    radial-gradient(ellipse 40% 50% at 10% 60%,rgba(123,47,190,.1) 0%,transparent 60%),
    var(--ink);
}
.hero-grid{
  position:absolute;inset:0;
  background-image:linear-gradient(rgba(201,168,76,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(201,168,76,.05) 1px,transparent 1px);
  background-size:60px 60px;
  mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 40%,transparent 100%);
}
.hero-content{position:relative;z-index:1;max-width:920px;text-align:center}
.hero-badge{
  display:inline-flex;align-items:center;gap:.5rem;
  background:rgba(201,168,76,.1);border:1px solid var(--border2);
  padding:.4rem 1rem;border-radius:50px;
  font-size:.72rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;
  color:var(--gold-light);margin-bottom:2rem;
  animation:fadeDown .8s ease both;
}
.hero-badge::before{content:'';width:6px;height:6px;background:var(--gold);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.hero h1{
  font-family:var(--font-display);font-size:clamp(2.6rem,6vw,5rem);
  font-weight:900;line-height:1.06;letter-spacing:-0.03em;
  animation:fadeUp .8s .2s ease both;margin-bottom:1.5rem;
}
.hero h1 .accent{
  background:linear-gradient(135deg,var(--gold),var(--gold-light),var(--accent));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
}
.hero-desc{font-size:1.1rem;line-height:1.7;opacity:.72;max-width:580px;margin:0 auto 2.5rem;animation:fadeUp .8s .35s ease both}
.hero-actions{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;animation:fadeUp .8s .5s ease both}
.btn-primary{background:linear-gradient(135deg,var(--gold),var(--gold-dark));color:var(--ink);padding:.875rem 2.5rem;border-radius:50px;font-weight:700;font-size:1rem;border:none;cursor:pointer;transition:all .25s;text-decoration:none;display:inline-block}
.btn-primary:hover{transform:translateY(-3px);box-shadow:0 12px 32px rgba(201,168,76,.5)}
.btn-outline{background:transparent;border:1.5px solid var(--border2);color:var(--cream);padding:.875rem 2.5rem;border-radius:50px;font-weight:500;font-size:1rem;cursor:pointer;transition:all .25s;text-decoration:none;display:inline-block}
.btn-outline:hover{border-color:var(--gold);color:var(--gold);background:rgba(201,168,76,.08);transform:translateY(-3px)}
.hero-stats{display:flex;gap:3rem;justify-content:center;margin-top:4rem;flex-wrap:wrap;animation:fadeUp .8s .65s ease both}
.stat{text-align:center}
.stat-num{font-family:var(--font-display);font-size:2.5rem;font-weight:900;color:var(--gold-light);display:block;line-height:1}
.stat-label{font-size:.75rem;opacity:.45;letter-spacing:.05em;text-transform:uppercase;margin-top:.3rem}

/* ── SECTIONS ── */
.section{padding:6rem 2rem}
.container{max-width:1200px;margin:0 auto}
.section-tag{font-size:.72rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);margin-bottom:.75rem}
.section-title{font-family:var(--font-display);font-size:clamp(1.8rem,4vw,2.9rem);font-weight:900;line-height:1.15;letter-spacing:-0.02em;margin-bottom:1rem}
.section-sub{font-size:.95rem;opacity:.62;line-height:1.7;max-width:480px}

/* ── ARTICULOS ── */
.articles-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.5rem;margin-top:3rem}
.article-card{
  background:var(--glass);border:1px solid var(--border);border-radius:var(--r2);
  padding:2rem;transition:all .3s;position:relative;overflow:hidden;text-decoration:none;color:var(--cream);display:block;
}
.article-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(201,168,76,.05),transparent);opacity:0;transition:opacity .3s}
.article-card:hover{transform:translateY(-6px);border-color:var(--border2);box-shadow:var(--shadow)}
.article-card:hover::before{opacity:1}
.article-cat{font-size:.68rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--gold);margin-bottom:.75rem}
.article-card h3{font-family:var(--font-display);font-size:1.25rem;font-weight:700;line-height:1.3;margin-bottom:.75rem}
.article-card p{font-size:.875rem;opacity:.6;line-height:1.65;margin-bottom:1.25rem}
.article-meta{display:flex;align-items:center;gap:.75rem;font-size:.75rem;opacity:.4}
.article-meta span{display:flex;align-items:center;gap:.3rem}

/* ── APPLETS ── */
.applets-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:1.5rem;margin-top:3rem}
.applet{background:var(--ink2);border:1px solid var(--border);border-radius:var(--r2);overflow:hidden}
.applet-header{padding:.875rem 1.5rem;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:.75rem;background:rgba(201,168,76,.04)}
.applet-dots{display:flex;gap:.4rem}
.applet-dots span{width:10px;height:10px;border-radius:50%}
.applet-title{font-size:.75rem;font-weight:600;opacity:.55;letter-spacing:.04em;margin:0 auto}
.applet-body{padding:1.4rem}
.clock-display{font-family:var(--font-display);font-size:3.2rem;font-weight:900;text-align:center;color:var(--gold-light);letter-spacing:.04em;line-height:1;margin-bottom:.4rem}
.clock-date{text-align:center;font-size:.82rem;opacity:.45;margin-bottom:1.4rem}
.clock-zones{display:grid;grid-template-columns:repeat(3,1fr);gap:.5rem}
.clock-zone{background:var(--glass);padding:.7rem .4rem;border-radius:var(--r);text-align:center}
.tz-city{font-size:.62rem;opacity:.45;text-transform:uppercase;letter-spacing:.05em}
.tz-time{font-size:.9rem;font-weight:600;color:var(--gold-light);margin-top:.2rem;font-family:var(--font-mono)}
.calc{background:#0D0D0D;border-radius:var(--r);overflow:hidden}
.calc-display{padding:1.25rem 1rem .875rem;text-align:right;background:rgba(0,0,0,.35);min-height:75px;display:flex;flex-direction:column;justify-content:flex-end}
.calc-prev{font-size:.75rem;opacity:.3;font-family:var(--font-mono);height:1.15rem}
.calc-current{font-size:1.9rem;font-weight:600;color:var(--gold-light);font-family:var(--font-mono)}
.calc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(255,255,255,.05)}
.calc-btn{padding:.875rem;font-size:.95rem;border:none;cursor:pointer;font-family:var(--font-mono);font-weight:500;background:var(--ink2);color:var(--cream);transition:background .15s,transform .1s}
.calc-btn:hover{background:rgba(201,168,76,.15)}
.calc-btn:active{transform:scale(.95)}
.calc-btn.op{color:var(--gold-light)}
.calc-btn.eq{background:var(--gold);color:var(--ink);font-weight:700}
.calc-btn.eq:hover{background:var(--gold-light)}
.calc-btn.wide{grid-column:span 2}

/* ── EMBEDS ── */
.embed-tabs{display:flex;gap:.5rem;margin-bottom:1.5rem;flex-wrap:wrap}
.embed-tab{padding:.55rem 1.15rem;border-radius:50px;font-size:.82rem;font-weight:500;cursor:pointer;background:var(--glass);border:1px solid var(--border);color:var(--cream);transition:all .2s}
.embed-tab.active,.embed-tab:hover{background:var(--gold);color:var(--ink);border-color:var(--gold);font-weight:700}
.embed-panel{display:none}
.embed-panel.active{display:block}
.youtube-embed{background:var(--ink2);border:1px solid var(--border);border-radius:var(--r2);overflow:hidden}
.yt-placeholder{aspect-ratio:16/9;background:linear-gradient(135deg,var(--ink2),var(--ink3));display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;position:relative;overflow:hidden;cursor:pointer}
.yt-placeholder::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 50%,rgba(255,0,0,.12),transparent 70%)}
.yt-play{width:68px;height:68px;border-radius:50%;background:rgba(255,0,0,.88);display:flex;align-items:center;justify-content:center;font-size:1.6rem;transition:transform .2s,background .2s;border:3px solid rgba(255,255,255,.15)}
.yt-placeholder:hover .yt-play{transform:scale(1.1);background:#FF0000}
.yt-info{padding:.875rem 1.5rem}
.yt-info h4{font-size:.95rem;font-weight:600;margin-bottom:.2rem}
.yt-info p{font-size:.75rem;opacity:.45}
.yt-url-input{display:flex;gap:.75rem;padding:.875rem 1.5rem;border-top:1px solid var(--border);flex-wrap:wrap}
.yt-url-input input{flex:1;min-width:180px;padding:.55rem 1rem;border-radius:var(--r);background:var(--ink);border:1px solid var(--border2);color:var(--cream);font-family:var(--font-body);font-size:.85rem;outline:none}
.yt-url-input input:focus{border-color:var(--gold)}
.yt-url-input button{padding:.55rem 1.1rem;border-radius:var(--r);background:var(--gold);color:var(--ink);font-weight:700;border:none;cursor:pointer;font-size:.85rem;transition:background .2s}
.yt-url-input button:hover{background:var(--gold-light)}
.spotify-embed{background:var(--ink2);border:1px solid var(--border);border-radius:var(--r2);overflow:hidden}
.sp-header{padding:1.25rem 1.5rem;background:linear-gradient(135deg,rgba(29,185,84,.14),transparent);display:flex;align-items:center;gap:1rem;border-bottom:1px solid var(--border)}
.sp-logo{width:46px;height:46px;background:#1DB954;border-radius:var(--r);display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0}
.sp-header h4{font-size:.95rem;font-weight:700}
.sp-header p{font-size:.75rem;opacity:.45;margin-top:.12rem}
.sp-track{display:flex;align-items:center;gap:.875rem;padding:.875rem 1.5rem;border-bottom:1px solid rgba(255,255,255,.04);cursor:pointer;transition:background .2s}
.sp-track:hover{background:rgba(255,255,255,.05)}
.sp-track.playing{background:rgba(29,185,84,.08)}
.sp-art{width:42px;height:42px;border-radius:6px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1rem}
.sp-info{flex:1;min-width:0}
.sp-info h5{font-size:.85rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sp-info span{font-size:.72rem;opacity:.45}
.sp-duration{font-size:.72rem;opacity:.35;font-family:var(--font-mono)}
.sp-progress{padding:1rem 1.5rem;border-top:1px solid var(--border)}
.sp-prog-bar{height:4px;background:rgba(255,255,255,.1);border-radius:2px;margin:.65rem 0;cursor:pointer}
.sp-prog-fill{height:100%;background:#1DB954;border-radius:2px;transition:width .5s}
.sp-controls{display:flex;align-items:center;justify-content:center;gap:1.1rem;margin-top:.4rem}
.sp-btn{background:none;border:none;color:var(--cream);cursor:pointer;font-size:1.05rem;opacity:.55;transition:opacity .2s,transform .2s;padding:.35rem}
.sp-btn:hover{opacity:1;transform:scale(1.15)}
.sp-btn.main{width:38px;height:38px;background:#1DB954;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.85rem;opacity:1;color:#000}
.sp-btn.main:hover{background:#1ed760;transform:scale(1.08)}

/* ── SOCIAL ── */
.social-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(175px,1fr));gap:1rem;margin-top:2rem}
.social-btn{display:flex;align-items:center;gap:.875rem;padding:.875rem 1.15rem;border-radius:var(--r2);border:1px solid var(--border);background:var(--glass);cursor:pointer;transition:all .25s;text-decoration:none;color:var(--cream)}
.social-btn:hover{transform:translateY(-4px);box-shadow:var(--shadow);border-color:var(--border2)}
.social-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0}
.social-info h5{font-size:.85rem;font-weight:600}
.social-info p{font-size:.68rem;opacity:.42;margin-top:.08rem}
.social-arrow{margin-left:auto;opacity:.28;font-size:.85rem;transition:opacity .2s,transform .2s}
.social-btn:hover .social-arrow{opacity:.75;transform:translateX(3px)}

/* ── FOOTER ── */
footer{background:var(--ink2);border-top:1px solid var(--border);padding:3rem 2rem 1.5rem}
.footer-grid{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:2rem;margin-bottom:3rem}
.footer-brand p{font-size:.85rem;opacity:.45;margin-top:.75rem;line-height:1.7;max-width:250px}
.footer-col h4{font-size:.7rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--gold);margin-bottom:.875rem}
.footer-col ul{list-style:none}
.footer-col li{margin-bottom:.55rem}
.footer-col a{font-size:.85rem;opacity:.45;text-decoration:none;color:var(--cream);transition:opacity .2s}
.footer-col a:hover{opacity:1;color:var(--gold)}
.footer-bottom{max-width:1200px;margin:0 auto;padding-top:1.5rem;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem}
.footer-bottom p{font-size:.75rem;opacity:.3}

/* ── ANIMATIONS ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeDown{from{opacity:0;transform:translateY(-12px)}to{opacity:1;transform:translateY(0)}}
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s,transform .7s}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ── THEMES ── */
body.theme-light{--ink:#F4F0E6;--ink2:#EAE4D4;--ink3:#DDD6C2;--cream:#1A1A2E;--glass:rgba(0,0,0,.05);--border:rgba(201,168,76,.2)}
body.theme-blue{--ink:#050D1A;--ink2:#091525;--ink3:#0E1E38;--gold:#4A8ED9;--gold-light:#7ABAF5;--gold-dark:#2466B0;--border:rgba(74,142,217,.22)}

/* ── RESPONSIVE ── */
@media(max-width:768px){
  .nav-links{display:none}
  .nav-links.open{display:flex;flex-direction:column;gap:1rem;position:fixed;top:68px;left:0;right:0;background:rgba(10,10,15,.98);padding:2rem;z-index:999;border-bottom:1px solid var(--border)}
  .hamburger{display:flex}
  .customizer{display:none}
  .hero h1{font-size:2.3rem}
  .applets-grid{grid-template-columns:1fr}
  .social-grid{grid-template-columns:repeat(2,1fr)}
  .hero-stats{gap:1.5rem}
}
@media(max-width:480px){
  .hero-actions{flex-direction:column;align-items:stretch}
  .btn-primary,.btn-outline{text-align:center}
  .social-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- NAVBAR -->
<nav class="nav" id="mainNav">
  <a href="#" class="nav-logo">✦ Javier Pino</a>
  <ul class="nav-links" id="navLinks">
    <li><a href="#articulos">Artículos</a></li>
    <li><a href="#sermones">Sermones</a></li>
    <li><a href="#multimedia">Multimedia</a></li>
    <li><a href="#social">Contacto</a></li>
    <li><a href="#articulos" class="nav-cta">Leer</a></li>
  </ul>
  <button class="hamburger" id="hamburger" aria-label="Menú">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- CUSTOMIZER -->
<div class="customizer">
  <button class="cust-btn" onclick="setTheme('')">🌙<span class="cust-tooltip">Tema Oscuro</span></button>
  <button class="cust-btn" onclick="setTheme('light')">☀️<span class="cust-tooltip">Tema Claro</span></button>
  <button class="cust-btn" onclick="setTheme('blue')">🔵<span class="cust-tooltip">Tema Azul</span></button>
  <button class="cust-btn" onclick="toggleFont()">Aa<span class="cust-tooltip">Cambiar Fuente</span></button>
  <button class="cust-btn" onclick="window.scrollTo({top:0,behavior:'smooth'})">↑<span class="cust-tooltip">Ir Arriba</span></button>
</div>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>
  <div class="hero-content">
    <div class="hero-badge">
      <span></span> Pastor Bautista Reformado · Teólogo · Estudiante de Teología
    </div>
    <h1>Javier Pino<br><span class="accent">Fe, Gracia<br>y Verdad</span></h1>
    <p class="hero-desc">Reflexiones teológicas desde la tradición reformada. Sermones, artículos y recursos para la edificación de la iglesia y el estudio serio de las Escrituras.</p>
    <div class="hero-actions">
      <a href="#articulos" class="btn-primary">Leer Artículos →</a>
      <a href="#sermones" class="btn-outline">Ver Sermones</a>
    </div>
    <div class="hero-stats">
      <div class="stat"><span class="stat-num">Sola</span><span class="stat-label">Scriptura</span></div>
      <div class="stat"><span class="stat-num">Sola</span><span class="stat-label">Gratia</span></div>
      <div class="stat"><span class="stat-num">Solus</span><span class="stat-label">Christus</span></div>
      <div class="stat"><span class="stat-num">Soli</span><span class="stat-label">Deo Gloria</span></div>
    </div>
  </div>
</section>

<!-- ARTÍCULOS -->
<section class="section" id="articulos">
  <div class="container">
    <div class="reveal">
