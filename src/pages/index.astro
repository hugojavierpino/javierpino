---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Obtener artículos ordenados por fecha
const allArticulos = await getCollection('articulos');
const articulos = allArticulos
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6);

const heroArticulos = articulos.slice(0, 3);
const listaArticulos = articulos.slice(1, 5);

function formatFecha(fecha: string | Date) {
  return new Date(fecha).toLocaleDateString('es-AR', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}

function leerMin(contenido: string) {
  const words = contenido?.split(' ').length ?? 200;
  return Math.max(1, Math.ceil(words / 200));
}
---

<Layout
  title="Javier Pino — Pastor · Teólogo · Reformado"
  description="Reflexiones bíblicas, teología reformada y sermones desde Neuquén, Argentina."
>

  <!-- ═══════════════════════════════════════════
       HERO CARRUSEL
  ═══════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-slides" id="slides">

        {heroArticulos.length > 0 ? heroArticulos.map((art, i) => (
          <div class={`hero-slide ${i === 0 ? 'active' : ''}`}>
            <div class="hero-content">
              <div class="hero-eyebrow">{art.data.categoria ?? 'Artículo destacado'}</div>
              <h1>{art.data.title}</h1>
              <p class="hero-excerpt">{art.data.resumen}</p>
              <div class="hero-meta">
                <span>{formatFecha(art.data.date)}</span>
                <span class="dot">·</span>
                <span>{leerMin(art.body)} min de lectura</span>
              </div>
              <a href={`/articulos/${art.id}`} class="btn">Leer artículo →</a>
            </div>
            <div class="hero-img">
              {art.data.imagen
                ? <img src={art.data.imagen} alt={art.data.title} loading={i === 0 ? 'eager' : 'lazy'} />
                : (
                  <div class="hero-img-placeholder">
                    <div class="ph-label">javierpino.org</div>
                  </div>
                )
              }
            </div>
          </div>
        )) : (
          <!-- Slide de bienvenida cuando no hay artículos -->
          <div class="hero-slide active">
            <div class="hero-content">
              <div class="hero-eyebrow">Bienvenido</div>
              <h1>Teología reformada desde el sur del mundo</h1>
              <p class="hero-excerpt">
                Un espacio para reflexionar sobre la Palabra de Dios, la sana
                doctrina y la vida cristiana en el contexto latinoamericano.
              </p>
              <div class="hero-meta">
                <span>Neuquén, Argentina</span>
                <span class="dot">·</span>
                <span>Pastor Bautista Reformado</span>
              </div>
              <a href="/sobre-mi" class="btn">Conocer más →</a>
            </div>
            <div class="hero-img">
              <div class="hero-img-placeholder">
                <div class="ph-label">javierpino.org</div>
              </div>
            </div>
          </div>
        )}

      </div>

      <!-- Dots de navegación -->
      <div class="hero-nav" id="heroDots">
        {heroArticulos.map((_, i) => (
          <button class={`hero-dot ${i === 0 ? 'active' : ''}`} aria-label={`Slide ${i + 1}`} data-slide={i}></button>
        ))}
      </div>

      <!-- Flechas -->
      {heroArticulos.length > 1 && (
        <div class="hero-arrows">
          <button class="hero-arrow" id="prevBtn" aria-label="Anterior">&#8679;</button>
          <button class="hero-arrow" id="nextBtn" aria-label="Siguiente">&#8681;</button>
        </div>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       LAYOUT PRINCIPAL
  ═══════════════════════════════════════════ -->
  <div class="layout">
    <main>

      <!-- ARTÍCULOS RECIENTES -->
      <div class="sh" id="articulos-section">
        <h2>Artículos recientes</h2>
        <a href="/articulos">Ver todos →</a>
      </div>

      {listaArticulos.length > 0 ? (
        <>
          <!-- Artículo destacado (primero de la lista) -->
          {listaArticulos[0] && (
            <div class="featured">
              <div class="feat-img">
                {listaArticulos[0].data.imagen
                  ? <img src={listaArticulos[0].data.imagen} alt={listaArticulos[0].data.title} loading="lazy" />
                  : <div class="ph-icon">📖</div>
                }
              </div>
              <div>
                <div class="cat-label">{listaArticulos[0].data.categoria ?? 'Artículo'}</div>
                <h3>
                  <a href={`/articulos/${listaArticulos[0].id}`}>{listaArticulos[0].data.title}</a>
                </h3>
                <p>{listaArticulos[0].data.resumen}</p>
                <div class="meta">
                  <span>{formatFecha(listaArticulos[0].data.date)}</span>
                  <span>·</span>
                  <span>{leerMin(listaArticulos[0].body)} min</span>
                </div>
              </div>
            </div>
          )}

          <!-- Lista del resto -->
          <div class="art-list">
            {listaArticulos.slice(1).map((art) => (
              <div class="art-item">
                <div class="art-thumb">
                  {art.data.imagen
                    ? <img src={art.data.imagen} alt={art.data.title} loading="lazy" />
                    : <span>📖</span>
                  }
                </div>
                <div>
                  <div class="cat-label">{art.data.categoria ?? 'Artículo'}</div>
                  <h4><a href={`/articulos/${art.id}`}>{art.data.title}</a></h4>
                  <p>{art.data.resumen}</p>
                  <div class="meta">
                    <span>{formatFecha(art.data.date)}</span>
                    <span>·</span>
                    <span>{leerMin(art.body)} min</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </>
      ) : (
        <div class="empty-state">
          <p>Los artículos aparecerán aquí a medida que los vayas publicando desde el panel de administración.</p>
          <a href="/articulos" class="btn" style="margin-top:1.25rem">Ir al listado →</a>
        </div>
      )}

      <!-- SERMONES -->
      <div class="sh" id="sermones" style="margin-top:3.5rem">
        <h2>Sermones</h2>
        <a href="/sermones">Ver todos →</a>
      </div>

      <div class="yt-coming">
        <div class="yt-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" width="36" height="36">
            <path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 001.46 6.42 29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/>
          </svg>
        </div>
        <p>Los sermones en video estarán disponibles próximamente en YouTube.</p>
        <span>Seguí las redes para enterarte cuando estén disponibles.</span>
      </div>

    </main>

    <!-- SIDEBAR -->
    <aside class="sidebar">

      <!-- Newsletter -->
      <div class="widget">
        <div class="sub-box">
          <h4>Newsletter</h4>
          <p>Recibí los nuevos artículos y sermones en tu correo.</p>
          <input type="email" placeholder="Tu email..." aria-label="Email para newsletter" />
          <button type="button">Suscribirme →</button>
        </div>
      </div>

      <!-- Artículos populares -->
      {articulos.length > 0 && (
        <div class="widget">
          <div class="widget-title">Artículos recientes</div>
          {articulos.slice(0, 4).map((art) => (
            <div class="sb-art">
              <h5><a href={`/articulos/${art.id}`}>{art.data.title}</a></h5>
              <span>{formatFecha(art.data.date)}</span>
            </div>
          ))}
        </div>
      )}

      <!-- Categorías -->
      <div class="widget">
        <div class="widget-title">Categorías</div>
        <div class="cats">
          <a href="/articulos?cat=teologia" class="cat-pill">Teología Sistemática</a>
          <a href="/articulos?cat=predicacion" class="cat-pill">Predicación</a>
          <a href="/articulos?cat=vida-cristiana" class="cat-pill">Vida Cristiana</a>
          <a href="/articulos?cat=historia" class="cat-pill">Historia</a>
          <a href="/articulos?cat=sermones" class="cat-pill">Sermones</a>
          <a href="/articulos?cat=reformada" class="cat-pill">Reformada</a>
        </div>
      </div>

      <!-- Sobre mí mini -->
      <div class="widget">
        <div class="widget-title">Sobre el autor</div>
        <div class="about-mini">
          <div class="about-mini-avatar">JP</div>
          <div>
            <strong>Javier Pino</strong>
            <p>Pastor bautista reformado, teólogo, esposo y abuelo. Neuquén, Argentina.</p>
            <a href="/sobre-mi">Leer más →</a>
          </div>
        </div>
      </div>

    </aside>
  </div>

  <!-- SOBRE MÍ STRIP -->
  <section class="about-strip" id="sobre-mi-strip">
    <div class="about-inner">
      <div class="about-photo" aria-label="Foto de Javier Pino">
        <span>JP</span>
      </div>
      <div class="about-text">
        <div class="about-eyebrow">Sobre mí</div>
        <h2>Javier Pino</h2>
        <p>
          Pastor bautista reformado en Neuquén, Argentina. Esposo, abuelo y estudiante
          de Licenciatura en Teología. Comprometido con la predicación fiel de la Palabra
          y la enseñanza de la teología reformada en el contexto latinoamericano.
        </p>
        <p>
          Este espacio nace del deseo de compartir reflexiones bíblicas, sermones y
          recursos para la iglesia que ama la sana doctrina.
        </p>
        <a href="/sobre-mi" class="btn btn-outline">Conocer más →</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── HERO ── */
  .hero {
    border-bottom: 1px solid var(--line);
    background: var(--off);
    overflow: hidden;
  }
  .hero-inner {
    max-width: var(--max);
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }
  .hero-slides {
    display: flex;
    transition: transform .55s cubic-bezier(.4,0,.2,1);
  }
  .hero-slide {
    min-width: 100%;
    display: grid;
    grid-template-columns: 1fr 380px;
    align-items: stretch;
  }
  .hero-content {
    padding: 3.5rem 3rem 3.5rem 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: .65rem;
    font-size: .65rem;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: .9rem;
  }
  .hero-eyebrow::before {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--gold);
    flex-shrink: 0;
  }
  .hero h1 {
    font-family: var(--fd);
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--navy);
    margin-bottom: 1rem;
  }
  .hero-excerpt {
    font-size: .92rem;
    color: var(--ink2);
    line-height: 1.8;
    margin-bottom: 1.25rem;
    max-width: 480px;
    font-style: italic;
    border-left: 2px solid var(--gold);
    padding-left: .9rem;
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: .75rem;
    font-size: .68rem;
    color: var(--ink2);
    margin-bottom: 1.25rem;
    font-weight: 500;
    flex-wrap: wrap;
  }
  .dot { color: var(--line2); }

  .hero-img {
    overflow: hidden;
    min-height: 300px;
    position: relative;
  }
  .hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-img-placeholder {
    width: 100%;
    height: 100%;
    min-height: 300px;
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy2) 60%, rgba(184,150,12,.4) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ph-label {
    font-family: var(--fd);
    font-size: 1rem;
    color: rgba(255,255,255,.2);
    letter-spacing: .15em;
    text-transform: uppercase;
    font-style: italic;
  }

  .hero-nav {
    position: absolute;
    bottom: 1.25rem;
    left: 2.5rem;
    display: flex;
    gap: .5rem;
    z-index: 10;
  }
  .hero-dot {
    width: 24px;
    height: 3px;
    background: rgba(13,27,62,.2);
    border: none;
    cursor: pointer;
    transition: all .2s;
    padding: 0;
  }
  .hero-dot.active {
    background: var(--gold);
    width: 36px;
  }
  .hero-arrows {
    position: absolute;
    top: 50%;
    right: 1rem;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: .4rem;
    z-index: 10;
  }
  .hero-arrow {
    width: 32px;
    height: 32px;
    background: rgba(255,255,255,.9);
    border: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: .9rem;
    color: var(--navy);
    transition: all .2s;
    padding: 0;
  }
  .hero-arrow:hover { background: var(--navy); color: var(--white); border-color: var(--navy); }

  /* ── LAYOUT ── */
  .layout {
    max-width: var(--max);
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
    display: grid;
    grid-template-columns: 1fr 270px;
    gap: 3.5rem;
  }

  /* ── FEATURED ── */
  .featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 2.5rem;
  }
  .feat-img {
    background: var(--off);
    border: 1px solid var(--line);
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    font-size: 3rem;
    color: var(--line2);
  }
  .feat-img img { width: 100%; height: 100%; object-fit: cover; }
  .featured h3 {
    font-family: var(--fd);
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--navy);
    margin-bottom: .65rem;
    margin-top: .1rem;
  }
  .featured h3 a { color: var(--navy); }
  .featured h3 a:hover { color: var(--gold); }
  .featured p { font-size: .88rem; color: var(--ink2); line-height: 1.75; margin-bottom: .65rem; }

  /* ── ARTICLE LIST ── */
  .art-list { display: flex; flex-direction: column; }
  .art-item {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 1.1rem;
    padding: 1.35rem 0;
    border-bottom: 1px solid var(--line);
    align-items: start;
  }
  .art-item:last-child { border-bottom: none; }
  .art-thumb {
    background: var(--off);
    border: 1px solid var(--line);
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    color: var(--line2);
    overflow: hidden;
    flex-shrink: 0;
  }
  .art-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .art-item h4 {
    font-family: var(--fd);
    font-size: .98rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--navy);
    margin-bottom: .25rem;
    margin-top: .1rem;
  }
  .art-item h4 a { color: var(--navy); }
  .art-item h4 a:hover { color: var(--gold); }
  .art-item p { font-size: .8rem; color: var(--ink2); line-height: 1.6; margin-bottom: .25rem; }

  /* ── SERMONES PLACEHOLDER ── */
  .yt-coming {
    border: 1px solid var(--line);
    padding: 2.5rem 2rem;
    text-align: center;
    background: var(--off);
  }
  .yt-icon { color: var(--line2); margin-bottom: .75rem; }
  .yt-coming p { font-size: .9rem; color: var(--ink2); margin-bottom: .35rem; }
  .yt-coming span { font-size: .75rem; color: var(--line2); }

  /* ── EMPTY STATE ── */
  .empty-state {
    padding: 3rem 2rem;
    text-align: center;
    border: 1px solid var(--line);
    color: var(--ink2);
    font-size: .9rem;
  }

  /* ── SIDEBAR ── */
  .sidebar { display: flex; flex-direction: column; gap: 2rem; }
  .widget {}
  .widget-title {
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--navy);
    border-bottom: 2px solid var(--navy);
    padding-bottom: .4rem;
    margin-bottom: 1rem;
  }
  .sub-box {
    background: var(--navy);
    padding: 1.5rem;
    color: white;
  }
  .sub-box h4 {
    font-family: var(--fd);
    font-size: 1rem;
    color: white;
    margin-bottom: .4rem;
  }
  .sub-box p { font-size: .78rem; color: rgba(255,255,255,.65); line-height: 1.6; margin-bottom: .85rem; }
  .sub-box input {
    width: 100%;
    padding: .5rem .75rem;
    font-size: .8rem;
    border: none;
    border-bottom: 1px solid rgba(255,255,255,.3);
    background: transparent;
    color: white;
    margin-bottom: .65rem;
    outline: none;
    font-family: var(--fs);
  }
  .sub-box input::placeholder { color: rgba(255,255,255,.35); }
  .sub-box button {
    width: 100%;
    padding: .55rem;
    background: var(--gold);
    color: white;
    border: none;
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .04em;
    cursor: pointer;
    font-family: var(--fs);
    transition: background .2s;
  }
  .sub-box button:hover { background: var(--gold-light); }

  .sb-art { padding: .75rem 0; border-bottom: 1px solid var(--line); }
  .sb-art:last-child { border-bottom: none; }
  .sb-art h5 {
    font-family: var(--fd);
    font-size: .85rem;
    color: var(--navy);
    line-height: 1.35;
    margin-bottom: .2rem;
    font-weight: 700;
  }
  .sb-art h5 a { color: var(--navy); }
  .sb-art h5 a:hover { color: var(--gold); }
  .sb-art span { font-size: .65rem; color: var(--ink2); }

  .cats { display: flex; flex-wrap: wrap; gap: .4rem; }
  .cat-pill {
    font-size: .62rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    border: 1px solid var(--line);
    color: var(--ink2);
    padding: .3rem .65rem;
    transition: all .2s;
  }
  .cat-pill:hover { border-color: var(--navy); color: var(--navy); }

  .about-mini { display: flex; gap: .85rem; align-items: flex-start; }
  .about-mini-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--navy);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .75rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .about-mini strong { font-size: .85rem; color: var(--navy); display: block; margin-bottom: .2rem; }
  .about-mini p { font-size: .78rem; color: var(--ink2); line-height: 1.5; margin-bottom: .4rem; }
  .about-mini a { font-size: .72rem; color: var(--gold); font-weight: 600; }

  /* ── SOBRE MÍ STRIP ── */
  .about-strip {
    background: var(--off);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .about-inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 3.5rem 2rem;
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 3rem;
    align-items: center;
  }
  .about-photo {
    background: var(--navy);
    aspect-ratio: 3/4;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--fd);
    font-size: 2.5rem;
    font-weight: 900;
    color: rgba(255,255,255,.15);
    letter-spacing: .05em;
  }
  .about-eyebrow {
    font-size: .65rem;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: .75rem;
    display: flex;
    align-items: center;
    gap: .5rem;
  }
  .about-eyebrow::before { content: ''; width: 20px; height: 1px; background: var(--gold); }
  .about-text h2 {
    font-family: var(--fd);
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    color: var(--navy);
    margin-bottom: .5rem;
    font-weight: 700;
  }
  .about-text p { font-size: .92rem; color: var(--ink2); line-height: 1.8; margin-bottom: .75rem; }
  .about-text .btn { margin-top: .25rem; }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .hero-slide { grid-template-columns: 1fr; }
    .hero-img { min-height: 200px; order: -1; }
    .hero-content { padding: 2rem 1.5rem; }
    .hero-arrows { right: .5rem; }
    .layout { grid-template-columns: 1fr; }
    .featured { grid-template-columns: 1fr; }
    .about-inner { grid-template-columns: 1fr; text-align: center; }
    .about-photo { width: 120px; margin: 0 auto; }
    .about-eyebrow { justify-content: center; }
  }
  @media (max-width: 580px) {
    .hero-content { padding: 1.5rem 1rem; }
    .hero-nav { left: 1rem; }
  }
</style>

<script>
  const slides = document.getElementById('slides');
  const dots = document.querySelectorAll('.hero-dot');
  const total = dots.length;
  let cur = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(n: number) {
    cur = (n + total) % total;
    if (slides) slides.style.transform = `translateX(-${cur * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle('active', i === cur));
    reset();
  }

  function reset() {
    clearInterval(timer);
    if (total > 1) timer = setInterval(() => goTo(cur + 1), 5500);
  }

  dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
  document.getElementById('prevBtn')?.addEventListener('click', () => goTo(cur - 1));
  document.getElementById('nextBtn')?.addEventListener('click', () => goTo(cur + 1));

  reset();
</script>
