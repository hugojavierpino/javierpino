<script>
// NAVBAR
document.getElementById('hamburger').addEventListener('click',()=>{
  document.getElementById('navLinks').classList.toggle('open');
});
window.addEventListener('scroll',()=>{
  document.getElementById('mainNav').style.boxShadow=window.scrollY>30?'0 4px 24px rgba(0,0,0,.45)':'none';
});

// SCROLL REVEAL
const obs=new IntersectionObserver(entries=>entries.forEach(e=>{
  if(e.isIntersecting)e.target.classList.add('visible');
}),{threshold:.12});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

// TEMAS
function setTheme(t){document.body.className='';if(t)document.body.classList.add('theme-'+t)}
const fontList=["'DM Sans',sans-serif","'Georgia',serif","'JetBrains Mono',monospace"];
let fIdx=0;
function toggleFont(){fIdx=(fIdx+1)%fontList.length;document.body.style.fontFamily=fontList[fIdx]}

// RELOJ
function updateClock(){
  const now=new Date();
  const p=n=>String(n).padStart(2,'0');
  document.getElementById('clock').textContent=`${p(now.getHours())}:${p(now.getMinutes())}:${p(now.getSeconds())}`;
  const days=['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
  const months=['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  document.getElementById('clockDate').textContent=`${days[now.getDay()]}, ${now.getDate()} de ${months[now.getMonth()]} ${now.getFullYear()}`;
  const fmt=tz=>new Intl.DateTimeFormat('es-AR',{hour:'2-digit',minute:'2-digit',hour12:false,timeZone:tz}).format(now);
  document.getElementById('tz-bue').textContent=fmt('America/Argentina/Buenos_Aires');
  document.getElementById('tz-mad').textContent=fmt('Europe/Madrid');
  document.getElementById('tz-ny').textContent=fmt('America/New_York');
}
setInterval(updateClock,1000);updateClock();

// CALCULADORA
let cs={d:'0',prev:'',op:'',newNum:true};
function updateCalc(){
  document.getElementById('calcCurrent').textContent=cs.d;
  document.getElementById('calcPrev').textContent=cs.prev+(cs.op?' '+cs.op:'');
}
function ca(v){
  if(v==='clear'){cs={d:'0',prev:'',op:'',newNum:true};}
  else if(v==='+/-'){cs.d=String(-parseFloat(cs.d)||0);}
  else if(v==='%'){cs.d=String(parseFloat(cs.d)/100);}
  else if(['+','-','*','/'].includes(v)){cs.prev=cs.d;cs.op=v;cs.newNum=true;}
  else if(v==='='){
    if(cs.op&&cs.prev){
      const a=parseFloat(cs.prev),b=parseFloat(cs.d);
      const res={'+':a+b,'-':a-b,'*':a*b,'/':b!==0?a/b:'Error'}[cs.op];
      cs.d=typeof res==='number'?String(parseFloat(res.toFixed(10))):'Error';
      cs.prev='';cs.op='';cs.newNum=true;
    }
  }else if(v==='.'){
    if(cs.newNum){cs.d='0.';cs.newNum=false;}
    else if(!cs.d.includes('.'))cs.d+='.';
  }else{
    if(cs.newNum||cs.d==='0'){cs.d=v;cs.newNum=false;}
    else if(cs.d.length<12)cs.d+=v;
  }
  updateCalc();
}

// EMBEDS
function switchEmbed(t,btn){
  document.querySelectorAll('.embed-tab').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.embed-panel').forEach(p=>p.classList.remove('active'));
  if(btn)btn.classList.add('active');
  document.getElementById('panel-'+t).classList.add('active');
}
function extractYTId(url){const m=url.match(/(?:v=|youtu\.be\/|shorts\/)([\w-]{11})/);return m?m[1]:null}
function embedYT(id){
  const frame=document.getElementById('ytFrame');
  const ph=document.getElementById('ytPlaceholder');
  frame.innerHTML=`<iframe width="100%" style="display:block;aspect-ratio:16/9;border:none" src="https://www.youtube.com/embed/${id}?autoplay=1&rel=0&modestbranding=1" allow="autoplay;encrypted-media" allowfullscreen></iframe>`;
  frame.style.display='block';ph.style.display='none';
  document.getElementById('ytTitle').textContent='Video cargado ✓';
  document.getElementById('ytSub').textContent='YouTube ID: '+id;
}
function loadDefaultYT(){embedYT('dQw4w9WgXcQ')}
function applyYT(){const id=extractYTId(document.getElementById('ytUrl').value.trim());if(id)embedYT(id);else document.getElementById('ytTitle').textContent='⚠ URL no válida'}

// SPOTIFY
const tracks=[
  {emoji:'🎸',color:'#FF5722',name:'Reformada y Profunda',artist:'Adoración Bautista',dur:'3:42'},
  {emoji:'🎹',color:'#4A6CF7',name:'Gracia que Salva',artist:'Himnos Clásicos',dur:'4:15'},
  {emoji:'🎺',color:'#C9A84C',name:'Solo Cristo',artist:'Fe Reformada',dur:'5:02'},
  {emoji:'🎻',color:'#1DB954',name:'Sola Scriptura',artist:'Alabanza Cristiana',dur:'3:28'},
  {emoji:'🥁',color:'#7B2FBE',name:'A Dios Sea la Gloria',artist:'Colección Reformada',dur:'4:55'},
];
let spPlaying=false,spIdx=0,spProg=0,spTimer=null;
function renderSp(){
  document.getElementById('spTracks').innerHTML=tracks.map((t,i)=>`
    <div class="sp-track${i===spIdx?' playing':''}" onclick="playTrack(${i})">
      <div class="sp-art" style="background:${t.color}22">${t.emoji}</div>
      <div class="sp-info"><h5>${t.name}</h5><span>${t.artist}</span></div>
      <span class="sp-duration">${t.dur}</span>
    </div>`).join('');
  document.getElementById('spTotal').textContent=tracks[spIdx].dur;
}
function playTrack(i){spIdx=i;spProg=0;document.getElementById('spFill').style.width='0%';document.getElementById('spCurrent').textContent='0:00';renderSp();if(spPlaying)startSpProgress()}
function spAct(a){
  if(a==='play'){spPlaying=!spPlaying;document.getElementById('spPlayBtn').textContent=spPlaying?'⏸':'▶';spPlaying?startSpProgress():clearInterval(spTimer);}
  else if(a==='next')playTrack((spIdx+1)%tracks.length);
  else if(a==='prev')playTrack((spIdx-1+tracks.length)%tracks.length);
}
function startSpProgress(){
  clearInterval(spTimer);
  const parts=tracks[spIdx].dur.split(':');
  const total=parseInt(parts[0])*60+parseInt(parts[1]);
  spTimer=setInterval(()=>{
    spProg=Math.min(spProg+1,total);
    document.getElementById('spFill').style.width=((spProg/total)*100).toFixed(1)+'%';
    document.getElementById('spCurrent').textContent=Math.floor(spProg/60)+':'+String(spProg%60).padStart(2,'0');
    if(spProg>=total)spAct('next');
  },1000);
}
function seekSp(e){const pct=e.offsetX/e.currentTarget.offsetWidth;const parts=tracks[spIdx].dur.split(':');spProg=Math.floor(pct*(parseInt(parts[0])*60+parseInt(parts[1])))}
renderSp();

// SOCIAL
const socials=[
  {icon:'📘',color:'#1877F2',name:'Facebook',sub:'Seguinos',url:'https://facebook.com'},
  {icon:'📸',color:'#E4405F',name:'Instagram',sub:'Ver perfil',url:'https://instagram.com'},
  {icon:'▶️',color:'#FF0000',name:'YouTube',sub:'Suscribirse',url:'https://youtube.com'},
  {icon:'💬',color:'#25D366',name:'WhatsApp',sub:'Contactar',url:'https://wa.me/'},
  {icon:'✈️',color:'#2AABEE',name:'Telegram',sub:'Unirse',url:'https://telegram.org'},
  {icon:'🐦',color:'#1DA1F2',name:'X / Twitter',sub:'Seguir',url:'https://twitter.com'},
  {icon:'🎵',color:'#1DB954',name:'Spotify',sub:'Escuchar',url:'https://spotify.com'},
  {icon:'💼',color:'#0A66C2',name:'LinkedIn',sub:'Conectar',url:'https://linkedin.com'},
];
document.getElementById('socialGrid').innerHTML=socials.map(s=>`
  <a href="${s.url}" target="_blank" rel="noopener" class="social-btn">
    <div class="social-icon" style="background:${s.color}22">${s.icon}</div>
    <div class="social-info"><h5>${s.name}</h5><p>${s.sub}</p></div>
    <span class="social-arrow">→</span>
  </a>`).join('');
</script>
