---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articulos = (await getCollection('articulos'))
  .filter(a => !a.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6);

function fecha(d: Date) {
  return d.toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' });
}
---
<Layout>
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-eyebrow">javierpino.org</div>
      <h1>Javier Pino</h1>
      <p class="hero-sub">Siervo de Jesucristo · Reflexiones bíblicas, teología reformada y predicación desde Neuquén, Argentina.</p>
      <div class="hero-links">
        <a href="/articulos" class="btn-primary">Ver artículos</a>
        <a href="/podcast" class="btn-ghost">Podcast</a>
      </div>
    </div>
  </section>

  {articulos.length > 0 && (
    <section class="recientes">
      <div class="recientes-inner">
        <div class="section-header">
          <h2>Artículos recientes</h2>
          <a href="/articulos" class="ver-todos">Ver todos →</a>
        </div>
        <div class="grid">
          {articulos.map((art, i) => (
            <a href={`/articulos/${art.id}`} class:list={['card', { featured: i === 0 }]}>
              <div class="card-cat">{art.data.categoria}</div>
              <h3 class="card-title">{art.data.title}</h3>
              {art.data.resumen && <p class="card-resumen">{art.data.resumen}</p>}
              <div class="card-fecha">{fecha(art.data.date)}</div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  /* HERO */
  .hero {
    background: var(--navy);
    border-bottom: 2px solid var(--gold);
    padding: 5rem 2rem 4rem;
  }
  .hero-inner { max-width: 760px; margin: 0 auto; }
  .hero-eyebrow {
    font-size: .65rem; font-weight: 700; letter-spacing: .15em;
    text-transform: uppercase; color: var(--gold-l); margin-bottom: 1.25rem;
  }
  .hero h1 {
    font-family: var(--fd); font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900; color: white; line-height: 1; margin-bottom: 1rem;
  }
  .hero-sub {
    font-size: 1.05rem; color: rgba(255,255,255,.65);
    line-height: 1.75; max-width: 540px; margin-bottom: 2rem;
  }
  .hero-links { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary {
    background: var(--gold); color: var(--navy);
    padding: .75rem 1.75rem; font-size: .75rem; font-weight: 700;
    letter-spacing: .08em; text-transform: uppercase; transition: opacity .2s;
  }
  .btn-primary:hover { opacity: .85; }
  .btn-ghost {
    border: 1px solid rgba(255,255,255,.3); color: white;
    padding: .75rem 1.75rem; font-size: .75rem; font-weight: 700;
    letter-spacing: .08em; text-transform: uppercase; transition: border-color .2s;
  }
  .btn-ghost:hover { border-color: var(--gold); color: var(--gold-l); }

  /* RECIENTES */
  .recientes { padding: 4rem 2rem; }
  .recientes-inner { max-width: 1200px; margin: 0 auto; }
  .section-header {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--line);
  }
  .section-header h2 {
    font-family: var(--fd); font-size: 1.5rem; font-weight: 700; color: var(--navy);
  }
  .ver-todos { font-size: .72rem; font-weight: 600; color: var(--gold); letter-spacing: .05em; }
  .ver-todos:hover { color: var(--navy); }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .card {
    display: block; padding: 1.75rem;
    border: 1px solid var(--line); background: var(--white);
    transition: border-color .2s, transform .2s;
  }
  .card:hover { border-color: var(--gold); transform: translateY(-2px); }
  .card.featured {
    grid-column: 1 / -1;
    display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;
    align-items: start; background: var(--navy);
    border-color: var(--navy);
  }
  .card-cat {
    font-size: .6rem; font-weight: 700; letter-spacing: .12em;
    text-transform: uppercase; color: var(--gold); margin-bottom: .75rem;
  }
  .card-title {
    font-family: var(--fd); font-size: 1.15rem; font-weight: 700;
    color: var(--navy); line-height: 1.25; margin-bottom: .6rem;
  }
  .card.featured .card-title { font-size: 1.6rem; color: white; }
  .card-resumen { font-size: .85rem; color: var(--ink2); line-height: 1.65; margin-bottom: 1rem; }
  .card.featured .card-resumen { color: rgba(255,255,255,.6); }
  .card-fecha { font-size: .65rem; color: var(--ink2); }
  .card.featured .card-fecha { color: rgba(255,255,255,.4); }

  @media (max-width: 900px) {
    .grid { grid-template-columns: 1fr 1fr; }
    .card.featured { grid-column: 1 / -1; grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .grid { grid-template-columns: 1fr; }
    .hero { padding: 3.5rem 1.25rem 3rem; }
    .recientes { padding: 3rem 1.25rem; }
  }
</style>
