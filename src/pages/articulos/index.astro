---
import { getCollection } from 'astro:content';

const articulos = await getCollection('articulos');
const sorted = articulos.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Artículos — Javier Pino</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:sans-serif;background:#fff;color:#222;max-width:800px;margin:0 auto;padding:2rem}
    h1{font-size:2rem;color:#0D1B3E;margin-bottom:.5rem}
    .subtitle{font-size:.9rem;color:#888;margin-bottom:3rem}
    .article-item{padding:2rem 0;border-bottom:1px solid #E2E2E2}
    .cat{font-size:.65rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#B8960C;margin-bottom:.5rem}
    .article-item h2{font-size:1.4rem;color:#0D1B3E;margin-bottom:.5rem}
    .article-item h2 a{color:#0D1B3E;text-decoration:none}
    .article-item h2 a:hover{color:#B8960C}
    .article-item p{font-size:.9rem;color:#555;line-height:1.7;margin-bottom:.75rem}
    .meta{font-size:.72rem;color:#888}
  </style>
</head>
<body>
  <a href="/" style="color:#0D1B3E;font-size:.85rem">✦ Javier Pino</a>
  <div style="margin-top:2rem">
    <h1>Artículos</h1>
    <p class="subtitle">Reflexiones teológicas desde la tradición reformada</p>
    {sorted.map(art => (
      <div class="article-item">
        <div class="cat">{art.data.categoria}</div>
        <h2><a href={`/articulos/${art.id}`}>{art.data.title}</a></h2>
        <p>{art.data.resumen}</p>
        <div class="meta">{art.data.date.toLocaleDateString('es-AR')}</div>
      </div>
    ))}
  </div>
</body>
</html>