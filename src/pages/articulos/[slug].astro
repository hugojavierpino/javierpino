---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articulos = await getCollection('articulos');
  return articulos.map(art => ({
    params: { slug: art.id },
    props: { art },
  }));
}

const { art } = Astro.props;
const { Content } = await render(art);
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{art.data.title} — Javier Pino</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:sans-serif;background:#fff;color:#222;max-width:720px;margin:0 auto;padding:2rem}
    h1{font-size:2rem;color:#0D1B3E;margin-bottom:1rem}
    .cat{font-size:.75rem;color:#B8960C;text-transform:uppercase;letter-spacing:.1em;margin-bottom:.5rem}
    .meta{font-size:.8rem;color:#888;margin-bottom:2rem}
    .back{display:block;margin-top:3rem;color:#0D1B3E}
  </style>
</head>
<body>
  <a href="/" style="color:#0D1B3E">✦ Javier Pino</a>
  <div style="margin-top:2rem">
    <div class="cat">{art.data.categoria}</div>
    <h1>{art.data.title}</h1>
    <div class="meta">{art.data.date.toLocaleDateString('es-AR')}</div>
    <div><Content /></div>
    <a href="/articulos" class="back">← Volver</a>
  </div>
</body>
</html>