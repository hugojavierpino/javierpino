---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articulos = await getCollection('articulos');
  return articulos
    .filter(a => !a.data.draft)
    .map(art => ({
      params: { slug: art.id },
      props: { art },
    }));
}

const { art } = Astro.props;
const { Content } = await render(art);

function formatFecha(fecha: Date) {
  return fecha.toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' });
}
function leerMin(contenido: string) {
  return Math.max(1, Math.ceil((contenido?.split(' ').length ?? 200) / 200));
}

// Prev / Next
const allArticulos = await getCollection('articulos');
const sorted = allArticulos
  .filter(a => !a.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const idx = sorted.findIndex(a => a.id === art.id);
const prev = idx < sorted.length - 1 ? sorted[idx + 1] : null;
const next = idx > 0 ? sorted[idx - 1] : null;

const mins = leerMin(art.body);
const fecha = formatFecha(art.data.date);
const canonicalUrl = `https://javierpino.org/articulos/${art.id}`;
---

<Layout
  title={`${art.data.title} — Javier Pino`}
  description={art.data.resumen}
  image={art.data.imagen}
>

  <!-- BREADCRUMB -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="bc-inner">
      <a href="/">Inicio</a>
      <span>›</span>
      <a href="/articulos">Artículos</a>
      <span>›</span>
      <span class="bc-current">{art.data.categoria}</span>
    </div>
  </nav>

  <!-- HEADER DEL ARTÍCULO -->
  <header class="art-header">
    <div class="art-header-inner">
      <div class="art-eyebrow">{art.data.categoria}</div>
      <h1>{art.data.title}</h1>
      {art.data.resumen && <p class="art-lead">{art.data.resumen}</p>}
      <div class="art-meta">
        <div class="art-author">
          <div class="author-av">JP</div>
          <div>
            <strong>Javier Pino</strong>
            <span>Pastor · Teólogo · Reformado</span>
          </div>
        </div>
        <div class="art-meta-right">
          <time datetime={art.data.date.toISOString()}>{fecha}</time>
          <span class="dot">·</span>
          <span>{mins} min de lectura</span>
        </div>
      </div>
    </div>
  </header>

  <!-- IMAGEN DESTACADA (si existe) -->
  {art.data.imagen && (
    <div class="featured-img">
      <img src={art.data.imagen} alt={art.data.title} loading="eager" />
    </div>
  )}

  <!-- CUERPO DEL ARTÍCULO -->
  <div class="art-wrap">
    <article class="prose" id="article-content">
      <Content />
    </article>

    <!-- COMPARTIR -->
    <div class="share-bar">
      <span class="share-label">Compartir</span>
      <a
        href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(art.data.title)}&url=${encodeURIComponent(canonicalUrl)}`}
        target="_blank" rel="noopener" class="share-btn" title="Compartir en Twitter/X"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.26 5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        Twitter / X
      </a>
      <a
        href={`https://wa.me/?text=${encodeURIComponent(art.data.title + ' ' + canonicalUrl)}`}
        target="_blank" rel="noopener" class="share-btn" title="Compartir en WhatsApp"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp
      </a>
      <button class="share-btn" id="copy-link" title="Copiar enlace">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
        <span id="copy-text">Copiar enlace</span>
      </button>
    </div>

    <!-- BIO DEL AUTOR -->
    <div class="author-bio">
      <div class="author-bio-av">JP</div>
      <div class="author-bio-body">
        <strong>Javier Pino</strong>
        <p>
          Pastor bautista reformado, teólogo y estudiante de Licenciatura en Teología.
          Neuquén, Argentina. Comprometido con la predicación fiel de la Palabra y la
          enseñanza de la teología reformada en el contexto latinoamericano.
        </p>
        <a href="/sobre-mi">Más sobre mí →</a>
      </div>
    </div>
  </div>

  <!-- NAVEGACIÓN PREV / NEXT -->
  {(prev || next) && (
    <nav class="art-nav" aria-label="Artículos anterior y siguiente">
      <div class="art-nav-inner">
        {prev ? (
          <a href={`/articulos/${prev.id}`} class="art-nav-item art-nav-prev">
            <span class="art-nav-dir">← Anterior</span>
            <div class="art-nav-meta">
              <span class="art-nav-cat">{prev.data.categoria}</span>
              <span class="art-nav-title">{prev.data.title}</span>
            </div>
          </a>
        ) : <div />}
        {next ? (
          <a href={`/articulos/${next.id}`} class="art-nav-item art-nav-next">
            <span class="art-nav-dir">Siguiente →</span>
            <div class="art-nav-meta">
              <span class="art-nav-cat">{next.data.categoria}</span>
              <span class="art-nav-title">{next.data.title}</span>
            </div>
          </a>
        ) : <div />}
      </div>
    </nav>
  )}

</Layout>

<style>
  /* BREADCRUMB */
  .breadcrumb { background: var(--off); border-bottom: 1px solid var(--line); }
  .bc-inner {
    max-width: 760px; margin: 0 auto;
    padding: .6rem 2rem;
    display: flex; align-items: center; gap: .5rem;
    font-size: .65rem; color: var(--ink2);
  }
  .bc-inner a { color: var(--ink2); }
  .bc-inner a:hover { color: var(--gold); }
  .bc-inner span { color: var(--line2); }
  .bc-current { color: var(--navy); font-weight: 600; }

  /* HEADER */
  .art-header { background: var(--navy); border-bottom: 2px solid var(--gold); padding: 3.5rem 2rem 2.5rem; }
  .art-header-inner { max-width: 760px; margin: 0 auto; }
  .art-eyebrow {
    font-size: .65rem; font-weight: 700; letter-spacing: .12em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 1rem;
    display: flex; align-items: center; gap: .5rem;
  }
  .art-eyebrow::before { content: ''; width: 20px; height: 1px; background: var(--gold); }
  .art-header h1 {
    font-family: var(--fd); font-size: clamp(1.8rem, 4.5vw, 2.9rem);
    font-weight: 900; color: white; line-height: 1.1;
    letter-spacing: -0.025em; margin-bottom: 1.1rem;
  }
  .art-lead {
    font-size: 1.05rem; color: rgba(255,255,255,.65); line-height: 1.75;
    font-style: italic; margin-bottom: 1.75rem;
    border-left: 3px solid var(--gold); padding-left: 1rem;
  }
  .art-meta {
    display: flex; align-items: center;
    justify-content: space-between; flex-wrap: wrap; gap: 1rem;
    padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,.12);
  }
  .art-author { display: flex; align-items: center; gap: .75rem; }
  .author-av {
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--gold); display: flex; align-items: center; justify-content: center;
    font-size: .72rem; font-weight: 700; color: white; flex-shrink: 0;
  }
  .art-author strong { display: block; font-size: .84rem; color: white; margin-bottom: .1rem; }
  .art-author span { font-size: .66rem; color: rgba(255,255,255,.45); }
  .art-meta-right { font-size: .72rem; color: rgba(255,255,255,.45); display: flex; gap: .4rem; align-items: center; }
  .dot { color: rgba(255,255,255,.2); }

  /* FEATURED IMAGE */
  .featured-img { max-width: 760px; margin: 0 auto; padding: 0 2rem; }
  .featured-img img {
    width: 100%; display: block;
    border: 1px solid var(--line);
    margin-top: 2.5rem;
  }

  /* ARTICLE WRAP */
  .art-wrap { max-width: 760px; margin: 0 auto; padding: 3rem 2rem 4rem; }

  /* PROSE — tipografía del artículo */
  .prose {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.13rem;
    line-height: 2;
    color: #1a1a1a;
  }

  /* Drop cap en el primer párrafo */
  .prose > p:first-of-type::first-letter {
    float: left;
    font-family: var(--fd);
    font-size: 4.2rem;
    font-weight: 900;
    line-height: .75;
    color: var(--navy);
    margin-right: .12em;
    margin-top: .1em;
  }

  .prose p { margin-bottom: 1.7rem; }
  .prose > p:last-of-type { margin-bottom: 0; }

  .prose h2 {
    font-family: var(--fd); font-size: 1.7rem; font-weight: 700;
    color: var(--navy); line-height: 1.15;
    margin-top: 3.5rem; margin-bottom: 1.1rem;
    letter-spacing: -0.01em;
    padding-bottom: .6rem; border-bottom: 1px solid var(--line);
  }
  .prose h3 {
    font-family: var(--fd); font-size: 1.3rem; font-weight: 700;
    color: var(--navy); line-height: 1.2;
    margin-top: 2.75rem; margin-bottom: .85rem;
  }
  .prose h4 {
    font-family: var(--fs); font-size: .72rem; font-weight: 700;
    color: var(--gold); letter-spacing: .12em; text-transform: uppercase;
    margin-top: 2.25rem; margin-bottom: .7rem;
  }

  .prose strong { font-weight: 700; color: var(--navy); }
  .prose em { font-style: italic; color: #2a2a2a; }

  .prose a {
    color: var(--gold);
    border-bottom: 1px solid rgba(184,150,12,.4);
    transition: all .2s;
  }
  .prose a:hover { color: var(--navy); border-color: var(--navy); }

  .prose ul {
    margin: .5rem 0 1.7rem 0;
    list-style: none; padding: 0;
  }
  .prose ul li {
    position: relative; padding-left: 1.5rem;
    margin-bottom: .65rem; line-height: 1.8;
  }
  .prose ul li::before {
    content: '—'; position: absolute; left: 0;
    color: var(--gold); font-weight: 700;
  }

  .prose ol {
    margin: .5rem 0 1.7rem 0;
    list-style: none; padding: 0; counter-reset: ol;
  }
  .prose ol li {
    position: relative; padding-left: 2.25rem;
    margin-bottom: .8rem; line-height: 1.8;
    counter-increment: ol;
  }
  .prose ol li::before {
    content: counter(ol) '.'; position: absolute; left: 0;
    font-family: var(--fd); font-size: .88rem; font-weight: 700;
    color: var(--gold); top: .15rem;
  }

  .prose blockquote {
    border-left: 3px solid var(--gold);
    margin: 2.75rem 0; padding: 1.35rem 1.85rem;
    background: var(--off); font-style: italic;
    color: #333; font-family: var(--fd); font-size: 1.08rem; line-height: 1.9;
  }
  .prose blockquote p { margin-bottom: 0; }

  .prose hr {
    border: none; text-align: center;
    margin: 3.5rem 0; color: var(--gold);
    font-size: 1.1rem; letter-spacing: .6em;
  }
  .prose hr::after { content: '✦  ✦  ✦'; }

  .prose img {
    max-width: 100%; margin: 2.5rem 0;
    border: 1px solid var(--line); display: block;
  }
  .prose code {
    background: var(--off); padding: .15rem .4rem;
    font-size: .88em; border: 1px solid var(--line); font-family: monospace;
  }

  /* SHARE BAR */
  .share-bar {
    display: flex; align-items: center; flex-wrap: wrap;
    gap: .65rem; margin-top: 3rem; padding-top: 1.75rem;
    border-top: 1px solid var(--line);
  }
  .share-label {
    font-size: .65rem; font-weight: 700; letter-spacing: .1em;
    text-transform: uppercase; color: var(--ink2); margin-right: .35rem;
  }
  .share-btn {
    display: inline-flex; align-items: center; gap: .45rem;
    font-size: .7rem; font-weight: 600; letter-spacing: .04em;
    border: 1px solid var(--line); color: var(--ink2); padding: .4rem .85rem;
    background: white; cursor: pointer; font-family: var(--fs);
    transition: all .2s; text-decoration: none;
  }
  .share-btn:hover { background: var(--navy); border-color: var(--navy); color: white; }

  /* AUTHOR BIO */
  .author-bio {
    display: flex; gap: 1.5rem; align-items: flex-start;
    margin-top: 3rem; padding: 2rem; background: var(--navy);
    border-left: 3px solid var(--gold);
  }
  .author-bio-av {
    width: 64px; height: 64px; border-radius: 50%; flex-shrink: 0;
    background: var(--gold); display: flex; align-items: center;
    justify-content: center; font-family: var(--fd); font-size: 1.3rem;
    font-weight: 900; color: white;
  }
  .author-bio-body strong {
    display: block; font-size: .95rem; color: white; margin-bottom: .4rem;
  }
  .author-bio-body p {
    font-size: .85rem; color: rgba(255,255,255,.6); line-height: 1.75; margin-bottom: .75rem;
    font-family: var(--fs);
  }
  .author-bio-body a { font-size: .78rem; color: var(--gold-light); font-weight: 600; }
  .author-bio-body a:hover { color: white; }

  /* PREV / NEXT NAV */
  .art-nav { border-top: 2px solid var(--navy); background: var(--off); }
  .art-nav-inner {
    max-width: 760px; margin: 0 auto;
    padding: 0 2rem;
    display: grid; grid-template-columns: 1fr 1fr;
  }
  .art-nav-item {
    padding: 1.75rem 1.25rem;
    display: flex; flex-direction: column; gap: .5rem;
    transition: background .2s;
  }
  .art-nav-item:hover { background: rgba(13,27,62,.04); }
  .art-nav-prev { border-right: 1px solid var(--line); padding-left: 0; }
  .art-nav-next { text-align: right; padding-right: 0; align-items: flex-end; }
  .art-nav-dir {
    font-size: .65rem; font-weight: 700; letter-spacing: .1em;
    text-transform: uppercase; color: var(--gold);
  }
  .art-nav-meta { display: flex; flex-direction: column; gap: .2rem; }
  .art-nav-cat {
    font-size: .6rem; font-weight: 600; letter-spacing: .08em;
    text-transform: uppercase; color: var(--ink2);
  }
  .art-nav-title {
    font-family: var(--fd); font-size: .95rem; font-weight: 700;
    color: var(--navy); line-height: 1.3;
  }
  .art-nav-item:hover .art-nav-title { color: var(--gold); }

  @media (max-width: 680px) {
    .art-header { padding: 2.5rem 1.25rem 2rem; }
    .art-header h1 { font-size: 1.7rem; }
    .art-wrap { padding: 2rem 1.25rem 3rem; }
    .featured-img { padding: 0 1.25rem; }
    .bc-inner { padding: .6rem 1.25rem; }
    .art-meta { flex-direction: column; align-items: flex-start; }
    .art-nav-inner { grid-template-columns: 1fr; }
    .art-nav-prev { border-right: none; border-bottom: 1px solid var(--line); }
    .art-nav-next { text-align: left; align-items: flex-start; }
    .author-bio { flex-direction: column; gap: 1rem; }
    .author-bio-av { width: 52px; height: 52px; }
  }
</style>

<script>
  const btn = document.getElementById('copy-link');
  const txt = document.getElementById('copy-text');
  btn?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(window.location.href);
    if (txt) txt.textContent = '¡Copiado!';
    setTimeout(() => { if (txt) txt.textContent = 'Copiar enlace'; }, 2000);
  });
</script>
