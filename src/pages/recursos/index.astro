---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Recursos" description="Recursos recomendados por Javier Pino.">
  <div class="page-header">
    <div class="page-header-inner">
      <div class="eyebrow">javierpino.org</div>
      <h1>Recursos</h1>
      <p>Libros, artículos y materiales recomendados</p>
    </div>
  </div>
  <div class="content">
    <p>Los recursos estarán disponibles pronto.</p>
  </div>
</Layout>

<style>
  .page-header { background: var(--navy); border-bottom: 2px solid var(--gold); padding: 3.5rem 2rem 2.5rem; }
  .page-header-inner { max-width: 760px; margin: 0 auto; }
  .eyebrow { font-size: .6rem; font-weight: 700; letter-spacing: .15em; text-transform: uppercase; color: var(--gold-l); margin-bottom: .75rem; }
  h1 { font-family: var(--fd); font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; color: white; margin-bottom: .5rem; }
  p { font-size: .9rem; color: rgba(255,255,255,.55); }
  .content { max-width: 760px; margin: 3rem auto; padding: 0 2rem; color: var(--ink2); }
</style>
