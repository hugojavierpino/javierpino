---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Podcast — Javier Pino" description="Podcast de Javier Pino.">
  <div class="page-header">
    <div class="inner">
      <div class="eyebrow">javierpino.org</div>
      <h1>Podcast</h1>
      <p>Próximamente</p>
    </div>
  </div>
</Layout>
<style>
  .page-header { background: var(--navy); border-bottom: 2px solid var(--gold); padding: 5rem 2rem; }
  .inner { max-width: 720px; margin: 0 auto; }
  .eyebrow { font-size: .65rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--gold); margin-bottom: .75rem; }
  h1 { font-family: var(--fd); font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; color: white; margin-bottom: .75rem; }
  p { color: rgba(255,255,255,.5); font-style: italic; }
</style>
