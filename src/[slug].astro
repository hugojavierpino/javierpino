---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articulos = await getCollection('articulos');
  return articulos.map(art => ({
    params: { slug: art.id },
    props: { art },
  }));
}

const { art } = Astro.props;
const { Content } = await render(art);

function formatFecha(fecha: Date) {
  return fecha.toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' });
}
function leerMin(contenido: string) {
  return Math.max(1, Math.ceil((contenido?.split(' ').length ?? 200) / 200));
}

const allArticulos = await getCollection('articulos');
const relacionados = allArticulos
  .filter(a => a.id !== art.id && a.data.categoria === art.data.categoria)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<Layout title={`${art.data.title} — Javier Pino`} description={art.data.resumen}>

  <div class="art-header">
    <div class="art-header-inner">
      <div class="art-eyebrow">{art.data.categoria}</div>
      <h1>{art.data.title}</h1>
      <p class="art-lead">{art.data.resumen}</p>
      <div class="art-meta-bar">
        <div class="art-author">
          <div class="author-avatar">JP</div>
          <div>
            <strong>Javier Pino</strong>
            <span>Pastor · Teólogo · Reformado</span>
          </div>
        </div>
        <div class="art-meta-right">
          <span>{formatFecha(art.data.date)}</span>
          <span class="sep">·</span>
          <span>{leerMin(art.body)} min de lectura</span>
        </div>
      </div>
    </div>
  </div>

  <div class="art-layout">
    <article class="art-body prose">
      <Content />
    </article>

    <aside class="sidebar">
      <div class="widget">
        <div class="sub-box">
          <h4>Newsletter</h4>
          <p>Recibí los próximos artículos en tu correo.</p>
          <input type="email" placeholder="Tu email..." />
          <button type="button">Suscribirme →</button>
        </div>
      </div>

      {relacionados.length > 0 && (
        <div class="widget">
          <div class="widget-title">Artículos relacionados</div>
          {relacionados.map(rel => (
            <div class="sb-art">
              <h5><a href={`/articulos/${rel.id}`}>{rel.data.title}</a></h5>
              <span>{formatFecha(rel.data.date)}</span>
            </div>
          ))}
        </div>
      )}

      <div class="widget">
        <div class="widget-title">Sobre el autor</div>
        <div class="about-mini">
          <div class="about-mini-avatar">JP</div>
          <div>
            <strong>Javier Pino</strong>
            <p>Pastor bautista reformado, teólogo. Neuquén, Argentina.</p>
            <a href="/sobre-mi">Leer más →</a>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <div class="art-footer-nav">
    <div class="art-footer-nav-inner">
      <a href="/articulos" class="btn btn-outline">← Todos los artículos</a>
    </div>
  </div>

</Layout>

<style>
  .art-header{background:var(--navy);border-bottom:2px solid var(--gold);padding:3.5rem 2rem 2.5rem}
  .art-header-inner{max-width:760px;margin:0 auto}
  .art-eyebrow{font-size:.65rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem;display:flex;align-items:center;gap:.5rem}
  .art-eyebrow::before{content:'';width:20px;height:1px;background:var(--gold)}
  .art-header h1{font-family:var(--fd);font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;color:white;line-height:1.1;letter-spacing:-0.02em;margin-bottom:1rem}
  .art-lead{font-size:1rem;color:rgba(255,255,255,.65);line-height:1.7;font-style:italic;margin-bottom:1.5rem;border-left:2px solid var(--gold);padding-left:.9rem}
  .art-meta-bar{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem}
  .art-author{display:flex;align-items:center;gap:.75rem}
  .author-avatar{width:38px;height:38px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:700;color:white;flex-shrink:0}
  .art-author strong{display:block;font-size:.82rem;color:white}
  .art-author span{font-size:.68rem;color:rgba(255,255,255,.45)}
  .art-meta-right{font-size:.72rem;color:rgba(255,255,255,.45)}
  .sep{margin:0 .35rem}
  .art-layout{max-width:var(--max);margin:0 auto;padding:3rem 2rem 5rem;display:grid;grid-template-columns:1fr 270px;gap:3.5rem;align-items:start}
  .prose{font-family:var(--fs);font-size:1.05rem;line-height:1.85;color:var(--ink)}
  .prose h1,.prose h2,.prose h3,.prose h4{font-family:var(--fd);color:var(--navy);line-height:1.2;margin-top:2.5rem;margin-bottom:.85rem;letter-spacing:-0.01em}
  .prose h2{font-size:1.6rem;font-weight:700}.prose h3{font-size:1.25rem;font-weight:700}.prose h4{font-size:1.05rem;font-weight:700}
  .prose p{margin-bottom:1.35rem}
  .prose a{color:var(--gold);border-bottom:1px solid var(--gold)}.prose a:hover{color:var(--navy);border-color:var(--navy)}
  .prose strong{font-weight:600;color:var(--navy)}.prose em{font-style:italic}
  .prose blockquote{border-left:3px solid var(--gold);margin:2rem 0;padding:1rem 1.5rem;background:var(--off);font-style:italic;color:var(--ink2);font-family:var(--fd);font-size:1.05rem}
  .prose blockquote p{margin-bottom:0}
  .prose ul,.prose ol{margin:1rem 0 1.35rem 1.5rem}.prose li{margin-bottom:.4rem}
  .prose hr{border:none;border-top:1px solid var(--line);margin:2.5rem 0}
  .prose img{max-width:100%;margin:1.5rem 0;border:1px solid var(--line)}
  .sidebar{display:flex;flex-direction:column;gap:2rem;position:sticky;top:80px}
  .widget-title{font-size:.65rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--navy);border-bottom:2px solid var(--navy);padding-bottom:.4rem;margin-bottom:1rem}
  .sub-box{background:var(--navy);padding:1.5rem;color:white}
  .sub-box h4{font-family:var(--fd);font-size:1rem;color:white;margin-bottom:.4rem}
  .sub-box p{font-size:.78rem;color:rgba(255,255,255,.65);line-height:1.6;margin-bottom:.85rem}
  .sub-box input{width:100%;padding:.5rem .75rem;font-size:.8rem;border:none;border-bottom:1px solid rgba(255,255,255,.3);background:transparent;color:white;margin-bottom:.65rem;outline:none;font-family:var(--fs)}
  .sub-box input::placeholder{color:rgba(255,255,255,.35)}
  .sub-box button{width:100%;padding:.55rem;background:var(--gold);color:white;border:none;font-size:.75rem;font-weight:600;cursor:pointer;font-family:var(--fs);transition:background .2s}
  .sub-box button:hover{background:var(--gold-light)}
  .sb-art{padding:.75rem 0;border-bottom:1px solid var(--line)}.sb-art:last-child{border-bottom:none}
  .sb-art h5{font-family:var(--fd);font-size:.85rem;color:var(--navy);line-height:1.35;margin-bottom:.2rem;font-weight:700}
  .sb-art h5 a{color:var(--navy)}.sb-art h5 a:hover{color:var(--gold)}
  .sb-art span{font-size:.65rem;color:var(--ink2)}
  .about-mini{display:flex;gap:.85rem;align-items:flex-start}
  .about-mini-avatar{width:40px;height:40px;border-radius:50%;background:var(--navy);color:white;display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;flex-shrink:0}
  .about-mini strong{font-size:.85rem;color:var(--navy);display:block;margin-bottom:.2rem}
  .about-mini p{font-size:.78rem;color:var(--ink2);line-height:1.5;margin-bottom:.4rem}
  .about-mini a{font-size:.72rem;color:var(--gold);font-weight:600}
  .art-footer-nav{border-top:1px solid var(--line);padding:2rem}
  .art-footer-nav-inner{max-width:var(--max);margin:0 auto}
  @media(max-width:900px){.art-layout{grid-template-columns:1fr}.sidebar{position:static}.art-meta-bar{flex-direction:column;align-items:flex-start}}
</style>
